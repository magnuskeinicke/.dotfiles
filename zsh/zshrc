# Set personal aliases, overriding those provided by oh-my-zsh libs,
# plugins, and themes. Aliases can be placed here, though oh-my-zsh
# users are encouraged to define aliases within the ZSH_CUSTOM folder.
# For a full list of active aliases, run `alias`.
#
# Example aliases
# alias zshconfig="mate ~/.zshrc"
# alias ohmyzsh="mate ~/.oh-my-zsh"

# Add true color
export COLORTERM=truecolor

source ~/.zsh_aliases
source ~/helpers.zsh

export GPG_TTY=$(tty)

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/bin" ] ; then
    PATH="$HOME/bin:$PATH"
fi

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/.local/bin" ] ; then
    PATH="$HOME/.local/bin:$PATH"
fi

source <(fzf --zsh)

#source /usr/share/fzf/shell/key-bindings.zsh

# Pick a clipboard command available in subshells (fzf bindings run in /bin/sh).
if command -v pbcopy >/dev/null 2>&1; then
  _CLIP_CMD="pbcopy"
elif command -v wl-copy >/dev/null 2>&1; then
  _CLIP_CMD="wl-copy"
elif command -v xclip >/dev/null 2>&1; then
  _CLIP_CMD="xclip -selection clipboard"
else
  _CLIP_CMD="cat >/dev/null"
fi

# Default fzf commands
export FZF_DEFAULT_COMMAND="fd --type file --no-ignore --follow --hidden --color=always --exclude .git"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type d --no-ignore"
export FZF_ALT_C_OPTS="
  --walker-skip .git,node_modules,target
  --preview 'tree -C {}'"
# CTRL-Y to copy the command into the system clipboard
export FZF_CTRL_R_OPTS="
  --bind 'ctrl-y:execute-silent(echo -n {2..} | $_CLIP_CMD)+abort'
  --color header:italic
  --header 'Press CTRL-Y to copy command into clipboard'"
# Preview file content using bat (https://github.com/sharkdp/bat)
export FZF_CTRL_T_OPTS="
  --walker-skip .git,node_modules,target
  --preview 'bat -n --color=always {}'
  --bind 'ctrl-/:change-preview-window(down|hidden|)'"
export FZF_DEFAULT_OPTS="--ansi"

# OS detection (used by secret lookup + tmux launcher below)
case "$(uname -s)" in
  Darwin*) OS_FAMILY=macos ;;
  Linux*)  OS_FAMILY=linux ;;
  *)       OS_FAMILY=unknown ;;
esac

# Look up a secret from the platform keychain.
# Usage: _secret <service-name>
# Linux: libsecret (`secret-tool`)
# macOS: Keychain (`security find-generic-password`)
_secret() {
  local service="$1"
  case "$OS_FAMILY" in
    linux)
      command -v secret-tool >/dev/null 2>&1 || return 0
      secret-tool lookup service "$service" user "$USER" 2>/dev/null
      ;;
    macos)
      command -v security >/dev/null 2>&1 || return 0
      security find-generic-password -a "$USER" -s "$service" -w 2>/dev/null
      ;;
  esac
}

# Personal access tokens
export GITHUB_PAT="$(_secret github-mcp)"
export FIGMA_PAT="$(_secret figma-mcp)"
export POSTHOG_PAT="$(_secret posthog-pat)"
export CROWDIN_MCP_PAT="$(_secret crowdin-mcp)"


# Start tmux if not inside tmux
if command -v tmux &> /dev/null && [ -n "$PS1" ] && [[ ! "$TERM" =~ screen ]] && [[ ! "$TERM" =~ tmux ]] && [[ "$TERM" == "xterm-ghostty" ]] && [ -z "$TMUX" ]; then
  exec tmux new-session -A -s main
fi

fpath+=${ZDOTDIR:-~}/.zsh_functions

eval "$(starship init zsh)"
eval "$(mise activate zsh)"

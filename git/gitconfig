[user]
	name = Magnus Keinicke
	email = github@alias.parlo.dk
	signingkey = ~/.ssh/id_ed25519.pub

[gpg]
	format = ssh

[commit]
	gpgsign = true

[tag]
	gpgsign = true

[pull]
	rebase = true

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[rerere]
	enabled = true

[column]
	ui = auto

[branch]
	sort = -committerdate

[diff]
	algorithm = histogram

[includeIf "gitdir:~/Documents/Work/"]
	path = ~/.gitconfig-work

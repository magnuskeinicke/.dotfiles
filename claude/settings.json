{
  "env": {
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "permissions": {
    "allow": [],
    "deny": []
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/copy-env-to-worktree.sh\"",
            "timeout": 15,
            "statusMessage": "Syncing gitignored local files into worktree..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "msg=$(jq -r '.message // \"Claude needs your attention\"'); if [ \"$(uname -s)\" = \"Darwin\" ]; then osascript -e \"display notification \\\"$msg\\\" with title \\\"Claude Code\\\"\"; else notify-send -u normal -a 'Claude Code' 'Claude Code' \"$msg\"; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/statusline-command.sh\"",
    "padding": 0
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "nx@nx-claude-plugins": true,
    "context7@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "theme": "dark"
}

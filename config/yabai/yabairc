#!/usr/bin/env sh

# Scripting addition (requires SIP partial-disable).
# For this to work you must configure sudo such that
# it will be able to run the command without password.
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

# Notify SketchyBar when spaces or displays change so it can refresh the
# workspace indicators. Idempotent if sketchybar isn't running yet.
yabai -m signal --add event=space_changed   action="sketchybar --trigger space_change"
yabai -m signal --add event=display_changed action="sketchybar --trigger display_change"

# When spaces are created/destroyed (e.g. by the dynamic-workspace skhd
# binding), rebuild SketchyBar's space pills to match yabai's reality.
yabai -m signal --add event=space_created   action="$HOME/.config/sketchybar/plugins/spaces_refresh.sh"
yabai -m signal --add event=space_destroyed action="$HOME/.config/sketchybar/plugins/spaces_refresh.sh"

# Reconcile spaces + sketchybar bars whenever displays are added or removed
# (external plug/unplug, lid open/close with externals attached). Without
# this, sketchybar can end up missing a bar instance on a newly-attached
# display and render its space pills on the wrong screen.
yabai -m signal --add event=display_added   action="$HOME/.config/yabai/scripts/reconcile-displays.sh"
yabai -m signal --add event=display_removed action="$HOME/.config/yabai/scripts/reconcile-displays.sh"

# Launch new app windows on the focused display instead of macOS's main
# (menu-bar) display. Triggered when Spotlight / Raycast / rcmd starts an
# app that isn't already running.
yabai -m signal --add event=window_created action="$HOME/.config/yabai/scripts/move-new-window-to-focus.sh"

# Auto-destroy empty dynamic workspaces. Window-move helpers
# (move-to-next-space.sh, swap-or-move.sh) call the script directly, so
# only window destroy + app termination need signal coverage here.
# The first MIN_PER_DISPLAY spaces (set inside the script) are preserved
# as predefined workspaces even when empty.
yabai -m signal --add event=window_destroyed       action="$HOME/.config/yabai/scripts/cleanup-empty-spaces.sh"
yabai -m signal --add event=application_terminated action="$HOME/.config/yabai/scripts/cleanup-empty-spaces.sh"

# Make sure the predefined workspaces exist (creates missing ones up to
# MIN_PER_DISPLAY per display). Idempotent — never destroys.
"$HOME/.config/yabai/scripts/init-workspaces.sh"

# Refresh SketchyBar's workspace pills now that yabai is up. Covers the
# cold-boot case where sketchybar started before yabai and ended up with
# no space items. No-op if sketchybar isn't running.
"$HOME/.config/sketchybar/plugins/spaces_refresh.sh" >/dev/null 2>&1 &

# Tiling layout: bsp = binary space partitioning (new windows auto-tile
# next to the focused one, like COSMIC). Alternatives: stack, float.
yabai -m config layout bsp

# Reserve 32 px at the top for SketchyBar (and 0 at the bottom). yabai
# will keep tiled windows out of this strip on every display.
yabai -m config external_bar all:32:0

# Padding and gaps (default: 0)
yabai -m config top_padding    10
yabai -m config bottom_padding 10
yabai -m config left_padding   10
yabai -m config right_padding  10
yabai -m config window_gap     10

# Shadows: only on floating windows (less visual noise in tiled layouts).
yabai -m config window_shadow float

# Opacity: yabai is the single source of truth — apps shouldn't set their own
# opacity (e.g. Ghostty's background-opacity is now 1.0), otherwise values
# multiply.
#
# `window_opacity` is OFF because yabai's built-in mode treats each
# display's key window as focused — windows on inactive displays then
# render at active opacity. refresh-opacity.sh (signal-driven below)
# enforces a single global focused window instead.
yabai -m config window_opacity        off
yabai -m config active_window_opacity 0.95
yabai -m config normal_window_opacity 0.8

# Drive opacity manually so only one window — the truly focused one —
# is at active opacity, regardless of how many displays are connected.
# Just one signal: every cross-space / cross-display / app-switch focus
# change ultimately emits window_focused, so subscribing to the other
# events would only multiply the same work.
yabai -m signal --add event=window_focused action="$HOME/.config/yabai/scripts/refresh-opacity.sh"

# One-shot full sweep so existing windows pick up correct opacity at
# startup. After this the diff-only signal handler keeps state in sync.
"$HOME/.config/yabai/scripts/init-opacity.sh" >/dev/null 2>&1 &

# Focus follows mouse (COSMIC-like): hovering a window focuses it.
# Options: autofocus (focus only), autoraise (focus + raise to top), off.
yabai -m config focus_follows_mouse autofocus

# Mouse follows focus: when focus changes via keyboard (e.g. cross-display
# focus moves), warp the cursor to the new focused window. Without this,
# the cursor can be on screen A while focus lives on screen B, producing
# the "two screens look focused at once" feeling and confusing macOS when
# you then trigger a space switch.
yabai -m config mouse_follows_focus on

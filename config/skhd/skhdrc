# skhd: COSMIC-style window management on macOS.
# Modifier `rcmd` = Right Command key — used as the dedicated "Super" key.
# Left Command keeps all its normal macOS duties (cmd+c, cmd+w, cmd+tab, etc.).
# Pairs with yabai (window commands are dispatched via `yabai -m ...`).
#
# Start as a service:  skhd --start-service
# Reload after edits:  skhd --reload

# --- Focus window (hjkl + arrows) ---
# Cycles across displays at the edge: when there's no neighbor window in
# the requested direction, focus jumps to the adjacent display and lands
# on the edge-most window facing back toward the source.
rcmd - h          : ~/.config/yabai/scripts/focus-or-display.sh west
rcmd - j          : ~/.config/yabai/scripts/focus-or-display.sh south
rcmd - k          : ~/.config/yabai/scripts/focus-or-display.sh north
rcmd - l          : ~/.config/yabai/scripts/focus-or-display.sh east
rcmd - left       : ~/.config/yabai/scripts/focus-or-display.sh west
rcmd - down       : ~/.config/yabai/scripts/focus-or-display.sh south
rcmd - up         : ~/.config/yabai/scripts/focus-or-display.sh north
rcmd - right      : ~/.config/yabai/scripts/focus-or-display.sh east

# --- Swap window in direction (hjkl + arrows) ---
# Horizontal swaps fall through to space moves at the edge of the workspace:
# swap east → if no east neighbor, move to next space (creating one if needed);
# swap west → if no west neighbor, move to prev space (no-op if first).
# Vertical swaps stay pure — there is no workspace semantics up/down.
shift + rcmd - h     : ~/.config/yabai/scripts/swap-or-move.sh west
shift + rcmd - j     : yabai -m window --swap south
shift + rcmd - k     : yabai -m window --swap north
shift + rcmd - l     : ~/.config/yabai/scripts/swap-or-move.sh east
shift + rcmd - left  : ~/.config/yabai/scripts/swap-or-move.sh west
shift + rcmd - down  : yabai -m window --swap south
shift + rcmd - up    : yabai -m window --swap north
shift + rcmd - right : ~/.config/yabai/scripts/swap-or-move.sh east

# --- Window actions ---
rcmd - q          : yabai -m window --close 2>/dev/null || osascript -e 'tell application "System Events" to keystroke "w" using command down'
rcmd - f          : yabai -m window --toggle zoom-fullscreen
rcmd - g          : yabai -m window --toggle float
rcmd - m          : yabai -m window --toggle zoom-parent
rcmd - s          : yabai -m window --toggle split

# --- App launchers ---
rcmd - t          : open -na Ghostty
rcmd - b          : open -a "Brave Browser"
rcmd - return     : osascript -e 'tell application "System Events" to key code 49 using command down'

# --- Layout (whole space) ---
rcmd - r          : yabai -m space --rotate 90
rcmd - e          : yabai -m space --balance
shift + rcmd - x  : yabai -m space --mirror x-axis
shift + rcmd - y  : yabai -m space --mirror y-axis

# --- Help ---
rcmd - c          : open -na Ghostty --args --command="less ~/.config/skhd/cheatsheet.txt"

# --- Spaces (workspaces) ---
# Focus by number. Requires SIP partial-disable for yabai's space focus;
# without it, fall back to macOS native ctrl+1..9 (set in System Settings).
rcmd - 1          : yabai -m space --focus 1
rcmd - 2          : yabai -m space --focus 2
rcmd - 3          : yabai -m space --focus 3
rcmd - 4          : yabai -m space --focus 4
rcmd - 5          : yabai -m space --focus 5
rcmd - 6          : yabai -m space --focus 6
rcmd - 7          : yabai -m space --focus 7
rcmd - 8          : yabai -m space --focus 8
rcmd - 9          : yabai -m space --focus 9

# Move focused window to space N
shift + rcmd - 1  : yabai -m window --space 1
shift + rcmd - 2  : yabai -m window --space 2
shift + rcmd - 3  : yabai -m window --space 3
shift + rcmd - 4  : yabai -m window --space 4
shift + rcmd - 5  : yabai -m window --space 5
shift + rcmd - 6  : yabai -m window --space 6
shift + rcmd - 7  : yabai -m window --space 7
shift + rcmd - 8  : yabai -m window --space 8
shift + rcmd - 9  : yabai -m window --space 9

# Cycle spaces — positional (rcmd+ctrl+h/l). Stays on the current display
# until its spaces run out, then hops to the adjacent display.
ctrl + rcmd - h     : ~/.config/yabai/scripts/space-cycle-positional.sh west
ctrl + rcmd - l     : ~/.config/yabai/scripts/space-cycle-positional.sh east
ctrl + rcmd - left  : ~/.config/yabai/scripts/space-cycle-positional.sh west
ctrl + rcmd - right : ~/.config/yabai/scripts/space-cycle-positional.sh east

# Cycle spaces — by global index, wrapping at the ends (rcmd+tab / +shift).
rcmd - tab          : ~/.config/yabai/scripts/space-cycle-index.sh next
shift + rcmd - tab  : ~/.config/yabai/scripts/space-cycle-index.sh prev

# Move focused window to prev/next space on the SAME display
# (COSMIC Super+Shift+Ctrl+arrow). Going "next" past the last space on
# this display creates a new one — dynamic workspaces, display-local.
shift + ctrl + rcmd - h     : ~/.config/yabai/scripts/move-to-prev-space.sh
shift + ctrl + rcmd - l     : ~/.config/yabai/scripts/move-to-next-space.sh
shift + ctrl + rcmd - left  : ~/.config/yabai/scripts/move-to-prev-space.sh
shift + ctrl + rcmd - right : ~/.config/yabai/scripts/move-to-next-space.sh

# --- Displays (monitors) ---
# Focus display by spatial direction. `prev`/`next` walk yabai's internal
# display index, which is not guaranteed to match physical left/right —
# `west`/`east` use actual geometry, so h is always the screen to the
# left and l always the screen to the right.
alt + rcmd - h     : yabai -m display --focus west
alt + rcmd - l     : yabai -m display --focus east
alt + rcmd - left  : yabai -m display --focus west
alt + rcmd - right : yabai -m display --focus east

# Move focused window to display in spatial direction (and follow it).
shift + alt + rcmd - h     : yabai -m window --display west --focus
shift + alt + rcmd - l     : yabai -m window --display east --focus
shift + alt + rcmd - left  : yabai -m window --display west --focus
shift + alt + rcmd - right : yabai -m window --display east --focus

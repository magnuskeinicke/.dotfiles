#!/usr/bin/env bash
# SketchyBar config — replaces the macOS menu bar with a per-display top bar
# showing workspace indicators, CPU load, and a clock.
# Reload after edits:  sketchybar --reload
# Restart service:     brew services restart sketchybar

PLUGIN_DIR="$CONFIG_DIR/plugins"

# Catppuccin Mocha palette (AARRGGBB).
BASE=0xee1e1e2e         # bar background (semi-transparent)
TEXT=0xffcdd6f4         # foreground / icon
SURFACE=0xff313244      # inactive space pill
ACCENT=0xffcba6f7       # mauve — active space
ACCENT_FG=0xff1e1e2e    # text on top of accent

# ---- Bar ----
sketchybar --bar position=top \
                 height=32 \
                 blur_radius=20 \
                 color=$BASE \
                 padding_left=10 \
                 padding_right=10 \
                 sticky=on

# ---- Defaults applied to every item ----
sketchybar --default updates=when_shown \
                     icon.font="JetBrainsMono Nerd Font:Bold:14.0" \
                     icon.color=$TEXT \
                     icon.padding_left=8 \
                     icon.padding_right=8 \
                     label.font="JetBrainsMono Nerd Font:Bold:13.0" \
                     label.color=$TEXT \
                     label.padding_left=4 \
                     label.padding_right=8 \
                     background.color=0x00000000 \
                     background.corner_radius=6 \
                     background.height=22

# ---- Workspaces (one item per yabai space, scoped to its display) ----
# Space pills are added by the refresh script, which is also re-run by
# yabai whenever a space is created or destroyed (see yabairc signals).
# Each pill subscribes to space_change so its highlight updates when
# yabai switches spaces.
"$PLUGIN_DIR/spaces_refresh.sh"

# ---- CPU (right) — click opens btop in a new Ghostty window ----
sketchybar --add item cpu right \
           --set cpu \
              update_freq=5 \
              icon="" \
              icon.padding_left=10 \
              click_script='open -na Ghostty --args --command="btop"' \
              script="$PLUGIN_DIR/cpu.sh"

# ---- Battery (right) — click opens Battery settings ----
sketchybar --add item battery right \
           --set battery \
              update_freq=60 \
              icon.padding_left=10 \
              script="$PLUGIN_DIR/battery.sh" \
              click_script='open "x-apple.systempreferences:com.apple.Battery-Settings.extension"'

# ---- Network (right) — click opens Wi-Fi / Network settings ----
sketchybar --add item network right \
           --set network \
              update_freq=15 \
              icon.padding_left=10 \
              script="$PLUGIN_DIR/network.sh" \
              click_script='open "x-apple.systempreferences:com.apple.wifi-settings-extension"'

# ---- Bluetooth (right) — click opens Bluetooth settings ----
sketchybar --add item bluetooth right \
           --set bluetooth \
              update_freq=60 \
              icon.padding_left=10 \
              script="$PLUGIN_DIR/bluetooth.sh" \
              click_script='open "x-apple.systempreferences:com.apple.BluetoothSettings"'

# ---- VPN (right) — click opens Proton VPN ----
sketchybar --add item vpn right \
           --set vpn \
              update_freq=10 \
              icon.padding_left=10 \
              script="$PLUGIN_DIR/vpn.sh" \
              click_script='open -a ProtonVPN'

# ---- Clock (right) — click opens Proton Mail ----
sketchybar --add item clock right \
           --set clock \
              update_freq=10 \
              icon.padding_left=10 \
              script="$PLUGIN_DIR/clock.sh" \
              click_script='open -a "Proton Mail" 2>/dev/null || open https://mail.proton.me'

sketchybar --update
